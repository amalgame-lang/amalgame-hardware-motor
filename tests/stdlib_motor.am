// Test motor drivers against fake HAL backends (no hardware).

namespace Tests

import Amalgame.Hal
import Amalgame.Hardware.Motor

public class FakePwm implements PwmOut {
    private period: int
    private duty:   int
    private en:     int
    public FakePwm() { this.period = 0; this.duty = 0; this.en = 0 }
    public bool SetFrequency(hz: int, dutyPercent: int) { this.period = 1000000000 / hz; this.duty = (this.period * dutyPercent) / 100; return true }
    public bool SetPeriod(ns: int) { this.period = ns; return true }
    public bool SetDuty(ns: int)   { this.duty = ns; return true }
    public bool Enable()  { this.en = 1; return true }
    public bool Disable() { this.en = 0; return true }
    public int DutyOf()   { return this.duty }
    public int PeriodOf() { return this.period }
}

public class FakeOut implements DigitalOut {
    private state: int
    private ops:   int
    public FakeOut() { this.state = 0; this.ops = 0 }
    public void Write(level: int) { this.state = level; this.ops = this.ops + 1 }
    public void High() { this.state = 1; this.ops = this.ops + 1 }
    public void Low()  { this.state = 0; this.ops = this.ops + 1 }
    public void Toggle() { if (this.state == 1) { this.state = 0 } else { this.state = 1 }; this.ops = this.ops + 1 }
    public int StateOf() { return this.state }
    public int Ops() { return this.ops }
}

public class FakeClock implements Clock {
    public FakeClock() { }
    public void DelayMs(ms: int) { }
    public void DelayUs(us: int) { }
    public int Millis() { return 0 }
    public int Micros() { return 0 }
}

public class FakeI2c implements I2cBus {
    private writes: int
    public FakeI2c() { this.writes = 0 }
    public bool WriteByte(addr: int, value: int) { this.writes = this.writes + 1; return true }
    public int  ReadByte(addr: int) { return 0 }
    public bool WriteReg(addr: int, reg: int, value: int) { this.writes = this.writes + 1; return true }
    public int  ReadReg(addr: int, reg: int) { return 0 }
    public bool WriteBytes(addr: int, bytes: List<int>) { this.writes = this.writes + 1; return true }
    public List<int> ReadBytes(addr: int, count: int) { let l: List<int> = new List<int>(); return l }
    public int Writes() { return this.writes }
}

public class Program {
    public static void Main(string[] args) {
        var fail: int = 0

        // Servo: 90° → mid pulse 1500 µs = 1_500_000 ns; period 20 ms.
        let p: FakePwm = new FakePwm()
        let s: Servo = new Servo(p)
        s.Write(90)
        if (p.PeriodOf() == 20000000) { Console.WriteLine("[PASS] servo period 50Hz") } else { Console.WriteLine("[FAIL] servo period"); fail = fail + 1 }
        if (p.DutyOf() == 1500000) { Console.WriteLine("[PASS] servo 90deg = 1.5ms") } else { Console.WriteLine("[FAIL] servo 90deg got " + String_FromInt(p.DutyOf())); fail = fail + 1 }
        s.Write(0)
        if (p.DutyOf() == 1000000) { Console.WriteLine("[PASS] servo 0deg = 1.0ms") } else { Console.WriteLine("[FAIL] servo 0deg"); fail = fail + 1 }

        // Relay active-high.
        let ro: FakeOut = new FakeOut()
        let r: Relay = new Relay(ro)
        r.On()
        if (ro.StateOf() == 1) { Console.WriteLine("[PASS] relay on") } else { Console.WriteLine("[FAIL] relay on"); fail = fail + 1 }
        r.Off()
        if (ro.StateOf() == 0) { Console.WriteLine("[PASS] relay off") } else { Console.WriteLine("[FAIL] relay off"); fail = fail + 1 }

        // Stepper: after 1 half-step from phase 0 → phase 1 (c1+c2 on).
        let a: FakeOut = new FakeOut()
        let b: FakeOut = new FakeOut()
        let c: FakeOut = new FakeOut()
        let d: FakeOut = new FakeOut()
        let st: Stepper = new Stepper(a, b, c, d, new FakeClock())
        st.Step(1, 0)
        if (a.StateOf() == 1 && b.StateOf() == 1 && c.StateOf() == 0) { Console.WriteLine("[PASS] stepper phase1") } else { Console.WriteLine("[FAIL] stepper phase1"); fail = fail + 1 }
        st.Release()
        if (a.StateOf() == 0 && b.StateOf() == 0) { Console.WriteLine("[PASS] stepper release") } else { Console.WriteLine("[FAIL] stepper release"); fail = fail + 1 }

        // PCA9685: a channel is a PwmOut → drives a Servo over I2C.
        let i2c: FakeI2c = new FakeI2c()
        let pca: Pca9685 = new Pca9685(i2c, 0x40, new FakeClock())
        let sv: Servo = new Servo(pca.Channel(0))   // concrete→PwmOut coercion
        sv.Write(90)
        if (i2c.Writes() > 0) { Console.WriteLine("[PASS] pca9685 drives servo over i2c (" + String_FromInt(i2c.Writes()) + " writes)") } else { Console.WriteLine("[FAIL] pca9685 no writes"); fail = fail + 1 }

        // A4988: 5 steps fwd → 10 STEP edges, DIR high.
        let stp: FakeOut = new FakeOut()
        let dr:  FakeOut = new FakeOut()
        let a49: A4988 = new A4988(stp, dr, new FakeClock())
        a49.Step(5, 0)
        if (stp.Ops() == 10 && dr.StateOf() == 1) { Console.WriteLine("[PASS] a4988 5 steps") } else { Console.WriteLine("[FAIL] a4988 ops=" + String_FromInt(stp.Ops())); fail = fail + 1 }

        // Buzzer: Tone sets the PWM frequency/duty + enables.
        let bp: FakePwm = new FakePwm()
        let bz: Buzzer = new Buzzer(bp, new FakeClock())
        bz.Tone(440, 5)
        if (bp.PeriodOf() > 0) { Console.WriteLine("[PASS] buzzer tone") } else { Console.WriteLine("[FAIL] buzzer tone"); fail = fail + 1 }

        // AccelStepper: 20 steps fwd → 40 STEP edges, DIR high, position 20.
        let astp: FakeOut = new FakeOut()
        let adr:  FakeOut = new FakeOut()
        let acc: AccelStepper = new AccelStepper(astp, adr, new FakeClock())
        acc.SetSpeedRange(2000, 400)
        acc.SetRampSteps(5)
        let pos: int = acc.MoveSteps(20)
        if (pos == 20 && astp.Ops() == 40 && adr.StateOf() == 1) { Console.WriteLine("[PASS] accelstepper +20 (pos=" + String_FromInt(pos) + ")") } else { Console.WriteLine("[FAIL] accelstepper pos=" + String_FromInt(pos) + " ops=" + String_FromInt(astp.Ops())); fail = fail + 1 }
        // Reverse back to 0 via MoveTo → DIR low, position 0.
        acc.MoveTo(0)
        if (acc.Position() == 0 && adr.StateOf() == 0) { Console.WriteLine("[PASS] accelstepper back to 0") } else { Console.WriteLine("[FAIL] accelstepper back pos=" + String_FromInt(acc.Position())); fail = fail + 1 }

        if (fail == 0) { Console.WriteLine("motor: all good") }
    }
}
